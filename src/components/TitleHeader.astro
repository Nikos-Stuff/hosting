---
const { sub } = Astro.props;
---

<div
  id="animate"
  class="relative top-0 left-0 w-svw h-svh flex items-center justify-start"
  style="opacity: 0"
>
  <div
    id="centerContent"
    class="relative w-svw h-svh flex items-center justify-start"
  >
    <div id="contentWrapper" class="p-4 md:p-10 w-full text-left z-1">
      <p
        id="subtitle"
        class="text-xl md:text-2xl lg:text-3xl font-semibold opacity-75"
      >
        {sub}
      </p>
      <p
        id="title"
        class="text-4xl md:text-5xl lg:text-6xl xl:text-9xl font-bold uppercase text-white leading-none"
      >
        Host your<br /><span id="text_flip">MINECRAFT SERVER</span><br />for
        free
      </p>
    </div>
  </div>

  <!-- Background tilted div in 3d space -->
  <div
    class="absolute top-0 right-0 w-full h-full rounded-xl border-2 border-white/25 scale-50 pointer-events-none bg-black/80"
    style="transform: translateX(35%) perspective(800px) rotateX(0deg) rotateY(-10deg);"
  >
  </div>
</div>

<script>
  import { gsap } from "gsap";

  function run() {
    const animateElement = document.querySelector<HTMLElement>("#animate");
    if (animateElement) {
      animateElement.style.backgroundColor = "rgba(0, 0, 0, 0)";
    }

    if (animateElement && animateElement.dataset.entryInit !== "true") {
      animateElement.dataset.entryInit = "true";
      gsap.fromTo(
        animateElement,
        { y: 80, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 2,
          ease: "power3.out",
          clearProps: "transform,opacity",
        },
      );
    }

    const texts = [
      "MINECRAFT SERVER",
      "HYTALE SERVER",
      "DISCORD BOT",
      "WEBSITE",
      "TERRARIA SERVER",
      "TS6 SERVER",
    ];

    const contextColors: Record<string, string[]> = {
      "MINECRAFT SERVER": ["#22c55e", "#84cc16", "#16a34a"],
      "HYTALE SERVER": ["#f59e0b", "#f97316", "#fde047"],
      "DISCORD BOT": ["#5865F2", "#7289DA", "#818CF8"],
      WEBSITE: ["#06b6d4", "#3b82f6", "#8b5cf6"],
      "TERRARIA SERVER": ["#10b981", "#65a30d", "#22c55e"],
      "TS6 SERVER": ["#2563eb", "#0ea5e9", "#38bdf8"],
    };

    const fallbackColors = [
      "#22c55e",
      "#3b82f6",
      "#8b5cf6",
      "#f59e0b",
      "#ef4444",
      "#06b6d4",
      "#10b981",
      "#ec4899",
    ];

    const pickColor = (text: string) => {
      const palette = contextColors[text] ?? fallbackColors;
      return palette[Math.floor(Math.random() * palette.length)];
    };

    const hexToRgba = (hex: string, alpha: number) => {
      const normalized = hex.replace("#", "");
      const full =
        normalized.length === 3
          ? normalized
              .split("")
              .map((char) => char + char)
              .join("")
          : normalized;

      const value = Number.parseInt(full, 16);
      const r = (value >> 16) & 255;
      const g = (value >> 8) & 255;
      const b = value & 255;

      return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    };

    const typewriterElement = document.querySelector<HTMLElement>("#text_flip");
    if (!typewriterElement || typewriterElement.dataset.flipInit === "true")
      return;
    typewriterElement.dataset.flipInit = "true";

    typewriterElement.style.display = "inline-block";
    typewriterElement.style.position = "relative";
    typewriterElement.style.overflow = "hidden";
    typewriterElement.style.whiteSpace = "nowrap";
    typewriterElement.style.verticalAlign = "bottom";

    const inner = document.createElement("span");
    inner.style.display = "inline-block";
    inner.style.whiteSpace = "nowrap";
    inner.style.lineHeight = "inherit";
    inner.style.transition = "color 0.25s ease";
    typewriterElement.textContent = "";
    typewriterElement.appendChild(inner);

    let index = 0;

    function showNextText() {
      const currentText = texts[index];
      const nextColor = pickColor(currentText);

      inner.textContent = currentText;
      gsap.set(inner, { color: nextColor });

      if (animateElement) {
        gsap.to(animateElement, {
          backgroundColor: hexToRgba(nextColor, 0.12),
          duration: 0.6,
          ease: "power2.out",
        });
      }

      const tl = gsap.timeline({
        onComplete: () => {
          index = (index + 1) % texts.length;
          showNextText();
        },
      });

      tl.fromTo(
        inner,
        { yPercent: 100, opacity: 0 },
        { yPercent: 0, opacity: 1, duration: 0.5, ease: "power3.out" },
      )
        .to({}, { duration: 2 })
        .to(inner, {
          yPercent: -100,
          opacity: 0,
          duration: 0.45,
          ease: "power3.in",
        });
    }

    showNextText();
  }

  const startWithDelay = () => {
    window.setTimeout(run, 100);
  };

  if (document.readyState === "complete") {
    startWithDelay();
  } else {
    window.addEventListener("load", startWithDelay, { once: true });
  }
</script>
