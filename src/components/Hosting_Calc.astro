<div>
  <div class="space-y-4 animate">
    <!-- Custom Dropdown location -->
    <div class="relative" id="location_dropdown">
      <p class="block text-sm font-medium mb-1">Choose Location:</p>

      <div
        data-tooltip="Selecting a nearby server reduces ping and improves speed."
        id="location_selected"
        class="border border-white/20 rounded-lg px-4 py-3 cursor-pointer flex justify-between items-center select-none hover:bg-white/10 transition-all duration-300 ease-in-out"
      >
        <div>
          <span class="fi fi-xx mr-5"></span>Click to choose location
        </div>
      </div>

      <div
        id="location_options"
        class="hide_scrollbar absolute w-full rounded-lg mt-1 overflow-auto max-h-0 transition-all duration-300 z-51 bg-black shadow-lg"
      >
        <div
          class="px-4 py-3 flex justify-between items-center cursor-pointer hover:bg-white/10"
          data-location_name="europe_free"
          data-tooltip="Ryzen 9 5950X based servers located in Europe"
        >
          <div>
            <span class="fi fi-eu mr-5"></span>Europe
          </div>
        </div>

        <div
          class="px-4 py-3 flex justify-between items-center cursor-pointer hover:bg-white/10"
          data-location_name="us_free"
          data-tooltip="EPYC based servers located in the United States"
        >
          <div>
            <span class="fi fi-us mr-5"></span>United States
          </div>
        </div>
      </div>
    </div>

    <!-- Custom Dropdown Eggs -->
    <div class="hide_scrollbar relative" id="egg_dropdown">
      <p class="block text-sm font-medium mb-1">Select "egg":</p>

      <div
        data-tooltip="Pick a server type for the game you want to run."
        id="egg_selected"
        class="border border-white/20 rounded-lg px-4 py-3 cursor-pointer flex justify-between items-center select-none hover:bg-white/10 transition-all duration-300 ease-in-out"
      >
        Click to choose egg
      </div>
      <a
        href="https://forms.gle/KXNLmxLib8ERo9vT7"
        target="_blank"
        class="text-xs italic"
      >
        We're missing something? Let us know!
      </a>

      <div
        id="egg_options"
        class="hide_scrollbar absolute w-full rounded-lg mt-1 overflow-auto max-h-0 transition-all duration-300 z-50 bg-black shadow-lg"
      >
        <div
          class="p-3 grid grid-cols-3 md:grid-cols-6 gap-2 justify-items-center"
        >
          <div
            hidden
            id="egg_template"
            data-egg_id="?"
            class="flex flex-col items-center px-2 py-3 rounded-lg cursor-pointer hover:bg-white/10 select-none transition-all"
          >
            <figure
              class="w-16 h-16 rounded-md overflow-hidden bg-white/5 flex items-center justify-center"
            >
              <img src="" alt="Loading" class="w-full h-full object-cover" />
            </figure>
            <span class="text-sm mt-2 text-center">Downloading...</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Subplan dropdown -->
    <div class="relative" id="subplan_dropdown">
      <p class="block text-sm font-medium mb-1">Select Subplan:</p>

      <div
        data-tooltip="Subplans are different server configurations with varying performance and prices. Choose one that fits your needs."
        id="subplan_selected"
        class="border border-white/20 rounded-lg px-4 py-3 cursor-pointer flex justify-between items-center select-none hover:bg-white/10 transition-all duration-300 ease-in-out"
      >
        <div>Click to choose subplan</div>
      </div>

      <div
        id="subplan_options"
        class="hide_scrollbar absolute w-full rounded-lg mt-1 overflow-auto max-h-0 transition-all duration-300 z-51 bg-black shadow-lg"
      >
        <div
          class="px-4 py-3 flex justify-between items-center cursor-pointer hover:bg-white/10"
          data-subplan_name="free"
          data-tooltip="Good old free plan. Specifications are scaled based on the egg you choose."
        >
          <div>Free</div>
        </div>

        <div
          class="px-4 py-3 flex justify-between items-center cursor-pointer hover:bg-white/10"
          data-subplan_name="friends"
          data-tooltip="Enhanced performance with more resources for growing projects </br> Performance: ★★★☆☆"
        >
          <div>Friends</div>
        </div>

        <div
          class="px-4 py-3 flex justify-between items-center cursor-pointer hover:bg-white/10"
          data-subplan_name="advanced"
          data-tooltip="Premium performance with the most resources for large projects </br> Performance: ★★★★★"
        >
          <div>Advanced</div>
        </div>
      </div>
    </div>

    <!-- Email Input for order -->
    <div class="relative">
      <p class="block text-sm font-medium mb-1">Your Email:</p>
      <input
        data-tooltip="Your auto-generated password will be sent here. No spam!"
        id="client_email"
        type="text"
        placeholder="example@xyz.com"
        class="w-full p-4 mt-5 border rounded-lg
              bg-transparent
             border-white/20 hover:bg-white/10
               focus:outline-none
             focus:border-white/40
               focus:ring-2 focus:ring-white/20
               focus:ring-offset-0
               transition-all duration-300 ease-out"
      />
    </div>

    <div class="flex justify-center my-4">
      <div class="w-full max-w-90 h-19.5 flex items-center justify-center">
        <!-- reserved box to avoid CLS and keep centered -->
        <div
          class="cf-turnstile"
          data-sitekey="0x4AAAAAACBNatxTQCTb20u7"
          data-theme="light"
          data-size="normal"
          data-callback="onTurnstileSuccess"
          data-expired-callback="onTurnstileExpired"
          style="min-height:78px;"
        >
        </div>
      </div>
    </div>

    <!-- Server specs preview ( CPU / RAM / SSD bars ) -->
    <div id="specs_preview" class="space-y-3">
      <p class="block text-sm font-medium mb-1">Overall Available Resources:</p>
      <div
        id="availability_bar"
        class="w-full bg-white/5 rounded-md h-5 relative"
        data-tooltip="-"
      >
        <div
          id="availability_after_bar"
          class="absolute h-full rounded-md transition-all duration-300 bg-gray-400"
          style="width: 0%; opacity: 0.5; z-index: 2;"
        >
        </div>
        <div
          id="availability_base_bar"
          class="relative h-full rounded-md transition-all duration-300 bg-white"
          style="width: 0%; z-index: 1;"
        >
        </div>
      </div>
      <p id="can_deploy" class="text-xs opacity-50">-</p>

      <p class="block text-sm font-medium mb-1">Server Specs Preview:</p>
      <div class="space-y-2">
        <div>
          <p class="text-xs mb-1">CPU</p>
          <div
            class="w-full bg-white/5 rounded-full h-2 relative"
            data-tooltip="-"
          >
            <div
              id="boost_cpu_bar"
              class="absolute h-full rounded-full transition-all duration-300 bg-purple-400"
              style="width: 0%"
            >
            </div>
            <div
              id="cpu_bar"
              class="relative h-full rounded-full transition-all duration-300 bg-white"
              style="width: 0%"
            >
            </div>
          </div>
        </div>

        <div>
          <p class="text-xs mb-1">RAM</p>
          <div
            class="w-full bg-white/5 rounded-full h-2 relative"
            data-tooltip="-"
          >
            <div
              id="boost_ram_bar"
              class="absolute h-full rounded-full transition-all duration-300 bg-purple-400"
              style="width: 0%"
            >
            </div>
            <div
              id="ram_bar"
              class="relative h-full rounded-full transition-all duration-300 bg-white"
              style="width: 0%"
            >
            </div>
          </div>
        </div>

        <div>
          <p class="text-xs mb-1">SSD Storage</p>
          <div
            class="w-full bg-white/5 rounded-full h-2 relative"
            data-tooltip="-"
          >
            <div
              id="boost_ssd_bar"
              class="absolute h-full rounded-full transition-all duration-300 bg-purple-400"
              style="width: 0%"
            >
            </div>
            <div
              id="ssd_bar"
              class="relative h-full rounded-full transition-all duration-300 bg-white"
              style="width: 0%"
            >
            </div>
          </div>
        </div>
      </div>

      <!-- Total cost -->
      <div class="flex justify-between items-center">
        <p class="text-lg font-semibold">Monthly Cost:</p>
        <p id="estimated_cost" class="text-4xl font-bold">-</p>
      </div>

      <div class="animate">
        <button
          id="place_order_btn"
          class="group w-full p-4 mt-5 gap-3 flex items-center border rounded-lg hover:bg-white/10 border-white/20 transition-all duration-300 ease-in-out"
        >
          <span
            class="w-full z-10 relative group-hover:text-white text-center transition-color duration-300"
          >
            Get My Server!
          </span>
        </button>
        <a
          href="https://billing.stripe.com/p/login/6oUaEWa7abrm9GSdzBdAk00"
          target="_blank"
          id="place_order_btn"
          class="group w-full h-5 p-4 mt-2 gap-3 flex
          items-center border rounded-lg hover:bg-white/10
          border-white/20 transition-all duration-300
          ease-in-out"
        >
          <span
            class="w-full z-10 relative group-hover:text-white text-center transition-color duration-300"
          >
            Manage Subscriptions
          </span>
        </a>
        <a href="/legal">
          <small>
            By creating a server, you agree to our <strong
              >Terms of Service</strong
            > & <strong>Privacy Policy</strong>.
          </small>
        </a>
      </div>
    </div>
  </div>

  <script>
    // ------------------------------
    // DOM ELEMENT REFERENCES
    // ------------------------------
    const locationDropdown = document.getElementById(
      "location_dropdown",
    ) as HTMLElement | null;
    const locationSelected = document.getElementById(
      "location_selected",
    ) as HTMLElement | null;
    const locationOptions = document.getElementById(
      "location_options",
    ) as HTMLElement | null;

    const eggDropdown = document.getElementById(
      "egg_dropdown",
    ) as HTMLElement | null;
    const eggSelected = document.getElementById(
      "egg_selected",
    ) as HTMLElement | null;
    const eggOptions = document.getElementById(
      "egg_options",
    ) as HTMLElement | null;
    const eggTemplate = document.getElementById(
      "egg_template",
    ) as HTMLElement | null;

    const subplanDropdown = document.getElementById(
      "subplan_dropdown",
    ) as HTMLElement | null;
    const subplanSelected = document.getElementById(
      "subplan_selected",
    ) as HTMLElement | null;
    const subplanOptions = document.getElementById(
      "subplan_options",
    ) as HTMLElement | null;

    const clientEmailInput = document.getElementById(
      "client_email",
    ) as HTMLInputElement | null;
    const placeOrderBtn = document.getElementById(
      "place_order_btn",
    ) as HTMLElement | null;
    const order_blocker = document.getElementById(
      "order_blocker",
    ) as HTMLElement | null;
    const order_status = document.getElementById(
      "order_activity",
    ) as HTMLElement | null;

    const cpuBar = document.getElementById("cpu_bar") as HTMLElement | null;
    const ramBar = document.getElementById("ram_bar") as HTMLElement | null;
    const ssdBar = document.getElementById("ssd_bar") as HTMLElement | null;

    const boostCpuBar = document.getElementById(
      "boost_cpu_bar",
    ) as HTMLElement | null;
    const boostRamBar = document.getElementById(
      "boost_ram_bar",
    ) as HTMLElement | null;
    const boostSsdBar = document.getElementById(
      "boost_ssd_bar",
    ) as HTMLElement | null;

    const availabilityBar = document.getElementById(
      "availability_base_bar",
    ) as HTMLElement | null;
    const availabilityAfterBar = document.getElementById(
      "availability_after_bar",
    ) as HTMLElement | null;
    const candeployText = document.getElementById(
      "can_deploy",
    ) as HTMLElement | null;

    const estimatedCost = document.getElementById(
      "estimated_cost",
    ) as HTMLElement | null;
    // ------------------------------

    const egg_list = "https://api.nikostuff.com/HostingPelicanData?list_eggs"; // API for eggs
    const order_api =
      "https://api.nikostuff.com/HostingOrderManager?place_order"; // API for placing / renewing stuff
    const specs_api =
      "https://api.nikostuff.com/HostingOrderManager?retrive_data"; // api for retriving specs / cost data based on selected options
    // specs api returns:
    // { "ram": 2, "disk": 5, "cpu": 100, "availability": 80, "price": 0, boost: { "ram": 0, "disk": 0, "cpu": 0 } }

    const data_storage: {
      egg_id: string;
      client_email: string;
      location: string;
      subplan: string;
      turnstile_token: string;
    } = {
      egg_id: "",
      client_email: "",
      subplan: "",
      location: "",
      turnstile_token: "",
    };

    // ------------------------------
    // UPDATE STATS AND COST FUNCTION
    // ------------------------------
    async function updateSpecsAndCost() {
      if (
        !data_storage.egg_id ||
        !data_storage.location ||
        !data_storage.subplan
      )
        return;

      try {
        const res = await fetch(specs_api, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            egg_id: data_storage.egg_id,
            location: data_storage.location,
            subplan: data_storage.subplan,
          }),
        });

        if (!res.ok) throw new Error("Failed to fetch specs and cost");

        const data = await res.json();

        const canDeploy =
          typeof data.can_deploy === "boolean" ? data.can_deploy : false;

        const cpuBaseRaw = Math.max(0, Number(data.cpu) || 0);
        const cpuBoostRaw = Math.max(0, Number(data.boost?.cpu) || 0);
        const cpuTotalRaw = cpuBaseRaw + cpuBoostRaw;

        const cpuMaxTotal = 800; // top limit
        const cpuBase = Math.min(100, (cpuBaseRaw / cpuMaxTotal) * 100);
        const cpuTotal = Math.min(100, (cpuTotalRaw / cpuMaxTotal) * 100);

        const ramBaseRaw = Math.max(0, Number(data.ram) || 0);
        const ramBoostRaw = Math.max(0, Number(data.boost?.ram) || 0);
        const ramBase = Math.max(0, Math.min(100, ramBaseRaw));
        const ramBoost = Math.max(0, Math.min(100, ramBoostRaw));
        const ramTotal = Math.max(0, Math.min(100, ramBase + ramBoost));

        const ssdBaseRaw = Math.max(0, Number(data.disk) || 0);
        const ssdBoostRaw = Math.max(0, Number(data.boost?.disk) || 0);
        const ssdBase = Math.max(0, Math.min(100, ssdBaseRaw));
        const ssdBoost = Math.max(0, Math.min(100, ssdBoostRaw));
        const ssdTotal = Math.max(0, Math.min(100, ssdBase + ssdBoost));

        // CPU
        if (cpuBar) {
          cpuBar.style.width = `${cpuBase}%`;
          cpuBar.parentElement?.setAttribute(
            "data-tooltip",
            `${cpuBaseRaw}%+${cpuBoostRaw}% CPU (total ${cpuTotalRaw}% CPU)`,
          );
        }
        if (boostCpuBar) {
          boostCpuBar.style.width = `${cpuTotal}%`;
        }

        // RAM
        if (ramBar) {
          ramBar.style.width = `${ramBase}%`;
          ramBar.parentElement?.setAttribute(
            "data-tooltip",
            `${ramBaseRaw}+${ramBoostRaw} GB RAM (total ${ramTotal} GB)`,
          );
        }
        if (boostRamBar) {
          boostRamBar.style.width = `${ramTotal}%`;
        }

        // SSD
        if (ssdBar) {
          ssdBar.style.width = `${ssdBase}%`;
          ssdBar.parentElement?.setAttribute(
            "data-tooltip",
            `${ssdBaseRaw}+${ssdBoostRaw} GB Storage (total ${ssdTotal} GB) </br> *Expandable storage - free of charge. Contact us via ticketing system after placing the order if you need more storage!`,
          );
        }
        if (boostSsdBar) {
          boostSsdBar.style.width = `${ssdTotal}%`;
        }

        if (estimatedCost) {
          estimatedCost.textContent = `$${data.price}`;
        }
        if (availabilityBar) {
          const availability = Math.max(
            0,
            Math.min(100, Number(data.availability) || 0),
          );
          availabilityBar.style.width = `${availability}%`;
          availabilityBar.parentElement?.setAttribute(
            "data-tooltip",
            `${availability}% Available Resources ( After this order, ${Math.max(
              0,
              Math.min(100, Number(data.availability_after) || 0),
            )}% will be available )`,
          );
        }

        if (availabilityAfterBar) {
          const availabilityAfter = Math.max(
            0,
            Math.min(100, Number(data.availability_after) || 0),
          );
          availabilityAfterBar.style.width = `${availabilityAfter}%`;
        }

        if (candeployText) {
          candeployText.textContent = canDeploy
            ? "Your server can be deployed!"
            : "Your server cannot be deployed due to insufficient resources.";
        }
      } catch (err) {
        console.error("Error updating specs and cost:", err);
      }
    }

    // ------------------------------
    // CLIENT EMAIL INPUT HANDLING (debounce 2s)
    // ------------------------------
    let emailTimer: ReturnType<typeof setTimeout> | undefined = undefined;
    function commitEmail() {
      if (!clientEmailInput) return;
      const val = clientEmailInput.value.trim();
      data_storage.client_email = val;
    }
    clientEmailInput?.addEventListener("input", () => {
      if (emailTimer) clearTimeout(emailTimer);
      emailTimer = setTimeout(commitEmail, 2000);
    });
    // also commit on blur immediately
    clientEmailInput?.addEventListener("blur", () => {
      if (emailTimer) clearTimeout(emailTimer);
      commitEmail();
    });

    // ------------------------------
    // Cloudflare Turnstile callbacks
    // ------------------------------
    (window as any).onTurnstileSuccess = (token: string) => {
      data_storage.turnstile_token = token || "";
    };
    (window as any).onTurnstileExpired = () => {
      data_storage.turnstile_token = "";
    };

    // ------------------------------
    // FETCH EGGS
    // ------------------------------

    type Egg = {
      id: number;
      name: string;
      desc: string;
      image: string;
    };

    async function fetchEggs() {
      try {
        const res = await fetch(egg_list);
        if (!res.ok) throw new Error("Błąd pobierania jajek");

        const data = await res.json();
        const grid = eggOptions?.querySelector(".p-3");
        if (!grid) return;

        // Create egg options
        const eggs = Object.values(data).filter(
          (item): item is Egg =>
            typeof item === "object" && item !== null && "id" in item,
        );

        for (const egg of eggs) {
          const eggOption = eggTemplate?.cloneNode(true);
          if (!(eggOption instanceof HTMLElement)) continue;

          eggOption.id = "";
          eggOption.classList.add("egg_option");
          eggOption.dataset.egg_id = String(egg.id);
          eggOption.dataset.tooltip = egg.desc;
          eggOption.hidden = false;

          const img = eggOption.querySelector("img");
          if (img) {
            img.src = egg.image || "/imgs/plc.png";
            img.alt = egg.name || "";
          }

          const label = eggOption.querySelector("span");
          if (label) label.textContent = egg.name || "";

          grid.appendChild(eggOption);
        }

        // Add click listeners for eggs
        eggOptions?.querySelectorAll(".egg_option")?.forEach((option) => {
          option.addEventListener("click", () => {
            if (!eggSelected || !eggOptions) return;
            const txt = option.querySelector("span")?.textContent?.trim() || "";
            eggSelected.textContent = txt;
            eggOptions.classList.remove("max-h-60");
            const selectedEggId = option.getAttribute("data-egg_id") || "";
            // store selected egg for ordering
            data_storage.egg_id = selectedEggId;
          });
        });
      } catch (e) {
        console.error(e);
      }
    }

    // ------------------------------
    // DROPDOWN TOGGLE HANDLERS
    // ------------------------------
    eggSelected?.addEventListener("click", () => {
      eggOptions?.classList.toggle("max-h-60");
    });

    locationSelected?.addEventListener("click", () => {
      locationOptions?.classList.toggle("max-h-60");
    });

    subplanSelected?.addEventListener("click", () => {
      subplanOptions?.classList.toggle("max-h-60");
    });
    // ------------------------------

    // Click outside to close dropdowns
    document.addEventListener("click", (e) => {
      const target = e.target;
      if (!(target instanceof Node) || !locationDropdown?.contains(target)) {
        locationOptions?.classList.remove("max-h-60");
      }
      if (!(target instanceof Node) || !eggDropdown?.contains(target)) {
        eggOptions?.classList.remove("max-h-60");
      }
      if (!(target instanceof Node) || !subplanDropdown?.contains(target)) {
        subplanOptions?.classList.remove("max-h-60");
      }
    });

    setInterval(updateSpecsAndCost, 2000);

    // ------------------------------
    // LOCATION OPTION SELECT
    // ------------------------------
    locationOptions
      ?.querySelectorAll("[data-location_name]")
      ?.forEach((option) => {
        option.addEventListener("click", () => {
          if (!locationSelected || !locationOptions) return;
          locationSelected.innerHTML = option.innerHTML;
          // store selected location for cost calc
          const selected = option.getAttribute("data-location_name") || "";
          locationOptions.classList.remove("max-h-60");
          // add to data storage for ordering
          data_storage.location = selected;
        });
      });

    // ------------------------------
    // SUBPLAN OPTION SELECT
    // ------------------------------
    subplanOptions
      ?.querySelectorAll("[data-subplan_name]")
      ?.forEach((option) => {
        option.addEventListener("click", () => {
          if (!subplanSelected || !subplanOptions) return;
          subplanSelected.innerHTML = option.innerHTML;
          // store selected subplan for cost calc
          const selected = option.getAttribute("data-subplan_name") || "";
          subplanOptions.classList.remove("max-h-60");
          // add to data storage for ordering
          data_storage.subplan = selected;
        });
      });

    placeOrderBtn?.addEventListener("click", async () => {
      // ensure latest email committed before sending
      if (emailTimer) clearTimeout(emailTimer);
      commitEmail();

      console.log("Placing order with data:", data_storage);
      // Simply unhide the order blocker and send the data to the order API without any further handling for now ( everything is server side )
      if (order_blocker) order_blocker.removeAttribute("hidden");
      if (!order_status) return;
      try {
        order_status.textContent = "Waiting for API response...";
        const res = await fetch(order_api, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data_storage),
        });

        if (!res.ok)
          throw new Error("Unknown error... (Can't reach the target URL)");

        const data = await res.json();

        if (data.error) throw new Error(data.error);

        // Redirect to payment / order page
        if (data.status === "task_created") {
          order_status.textContent =
            "Action completed successfully! Redirecting...";
          setTimeout(() => {
            if (order_blocker) order_blocker.setAttribute("hidden", "true");
            // api should return "redirect_url" in response, but if not, fallback to panel homepage
            const redirectUrl =
              typeof data.redirect_url === "string"
                ? data.redirect_url
                : "https://panel.nikostuff.com";
            window.location.href = redirectUrl;
          }, 3000);
        } else {
          if (order_blocker) order_blocker.setAttribute("hidden", "true");
          alert("Oops. Something went wrong. Please try again later.");
        }
      } catch (err) {
        console.error(err);
        if (order_blocker) order_blocker.setAttribute("hidden", "true");
        const errMsg =
          err && typeof err === "object" && "message" in err
            ? (err as any).message
            : String(err);
        alert("Failed to place order: " + errMsg);
      }

      // Refresh Turnstile
      (window as any).turnstile.reset();
    });

    // ------------------------------
    // INITIAL CALCULATION / EGGS INIT
    // ------------------------------
    fetchEggs();
  </script>
</div>
