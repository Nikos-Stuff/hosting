<div>
  <div class="space-y-4 animate">
    <!-- Custom Dropdown grid -->
    <div class="space-y-2" id="location_dropdown">
      <p class="block text-sm font-medium mb-1">Choose Location:</p>
      <!-- Scrollable locations grid -->
      <div
        id="location_options"
        class="hide_scrollbar max-h-52 overflow-auto rounded-lg border border-white/20 bg-black/40 p-3"
      >
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <div
            class="px-3 py-4 rounded-lg cursor-pointer hover:bg-white/10 transition-all duration-300 text-center select-none flex flex-col items-center justify-center"
            data-location_name="europe_free"
            data-tooltip="Ryzen 9 5950X based servers located in Europe"
          >
            <span class="fi fi-eu text-2xl mb-2 rounded-sm"></span>
            <span class="text-sm">Europe</span>
            <span class="ping text-xs opacity-50">Ping: 0ms</span>
          </div>

          <div
            class="px-3 py-4 rounded-lg cursor-pointer hover:bg-white/10 transition-all duration-300 text-center select-none flex flex-col items-center justify-center"
            data-location_name="us_free"
            data-tooltip="EPYC based servers located in the United States"
          >
            <span class="fi fi-us text-2xl mb-2 rounded-sm"></span>
            <span class="text-sm">United States</span>
            <span class="ping text-xs opacity-50">Ping: 0ms</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Eggs grid -->
    <div class="space-y-2" id="egg_dropdown">
      <p class="block text-sm font-medium mb-1">Select "egg":</p>

      <div
        id="egg_options"
        class="hide_scrollbar h-52 overflow-auto rounded-lg border border-white/20 bg-black/40 p-3"
      >
        <div
          class="p-3 grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3 justify-items-center auto-rows-fr items-stretch"
        >
          <div
            hidden
            id="egg_template"
            data-egg_id="?"
            class="flex h-full w-24 flex-col items-center px-2 py-3 rounded-lg cursor-pointer hover:bg-white/10 select-none transition-all border border-transparent"
          >
            <figure
              class="w-16 h-16 rounded-sm overflow-hidden bg-white/5 flex items-center justify-center shrink-0"
            >
              <img src="" alt="Loading" class="w-full h-full object-cover" />
            </figure>
            <span
              class="text-sm mt-2 text-center w-full whitespace-normal wrap-break-word leading-tight flex-1 flex items-center justify-center"
            >
              Downloading...
            </span>
          </div>
        </div>
      </div>

      <a
        href="https://forms.gle/KXNLmxLib8ERo9vT7"
        target="_blank"
        class="text-xs italic"
      >
        We're missing something? Let us know!
      </a>
    </div>

    <!-- Subplan dropdown -->
    <div class="relative" id="subplan_dropdown">
      <p class="block text-sm font-medium mb-1">Select Subplan:</p>

      <div
        data-tooltip="Subplans are different server configurations with varying performance and prices. Choose one that fits your needs."
        id="subplan_selected"
        class="border border-white/20 rounded-lg px-4 py-3 cursor-pointer flex justify-between items-center select-none hover:bg-white/10 transition-all duration-300 ease-in-out"
      >
        <div>Click to choose subplan</div>
      </div>

      <div
        id="subplan_options"
        class="hide_scrollbar absolute w-full rounded-lg mt-1 overflow-auto max-h-0 transition-all duration-300 z-51 bg-black shadow-lg"
      >
        <div
          class="px-4 py-3 flex justify-between items-center cursor-pointer hover:bg-white/10"
          data-subplan_name="free"
          data-tooltip="Good old free plan. Specifications are scaled based on the egg you choose."
        >
          <div>Free</div>
        </div>

        <div
          class="px-4 py-3 flex justify-between items-center cursor-pointer hover:bg-white/10"
          data-subplan_name="friends"
          data-tooltip="Enhanced performance with more resources for growing projects </br> Performance: ★★★☆☆"
        >
          <div>Friends</div>
        </div>

        <div
          class="px-4 py-3 flex justify-between items-center cursor-pointer hover:bg-white/10"
          data-subplan_name="advanced"
          data-tooltip="Premium performance with the most resources for large projects </br> Performance: ★★★★★"
        >
          <div>Advanced</div>
        </div>
      </div>
    </div>

    <!-- Email Input for order -->
    <div class="relative">
      <p class="block text-sm font-medium mb-1">Your Email:</p>
      <input
        data-tooltip="Your auto-generated password will be sent here. No spam!"
        id="client_email"
        type="text"
        placeholder="example@xyz.com"
        class="w-full p-4 border rounded-lg
              bg-transparent
             border-white/20 hover:bg-white/10
               focus:outline-none
             focus:border-white/40
               focus:ring-2 focus:ring-white/20
               focus:ring-offset-0
               transition-all duration-300 ease-out"
      />
    </div>

    <div class="flex justify-center my-4">
      <div class="w-full max-w-90 h-19.5 flex items-center justify-center">
        <!-- reserved box to avoid CLS and keep centered -->
        <div
          class="cf-turnstile"
          data-sitekey="0x4AAAAAACBNatxTQCTb20u7"
          data-theme="light"
          data-size="normal"
          data-callback="onTurnstileSuccess"
          data-expired-callback="onTurnstileExpired"
          style="min-height:78px;"
        >
        </div>
      </div>
    </div>

    <!-- Line -->
    <hr class="border-white/25 my-5" />

    <!-- Server specs preview ( CPU / RAM / SSD bars ) -->
    <div id="specs_preview" class="space-y-4">
      <div class="flex items-start gap-4">
        <div class="flex-1">
          <p class="block text-sm font-medium mb-2">Server Specs Preview:</p>

          <div class="h-28 flex flex-col justify-between">
            <div>
              <div
                class="w-full bg-white/5 rounded-md h-5 relative overflow-hidden"
                data-tooltip="-"
              >
                <div
                  id="boost_cpu_bar"
                  class="absolute h-full rounded-md transition-all duration-300 bg-purple-400/70"
                  style="width: 0%"
                >
                </div>
                <div
                  id="cpu_bar"
                  class="relative h-full rounded-md transition-all duration-300 bg-white"
                  style="width: 0%"
                >
                </div>
                <span
                  class="absolute inset-0 z-10 flex items-center justify-center text-[11px] font-semibold text-white"
                  style="text-shadow: 0 1px 2px rgba(0,0,0,0.8);"
                >
                  CPU
                </span>
              </div>
            </div>

            <div>
              <div
                class="w-full bg-white/5 rounded-md h-5 relative overflow-hidden"
                data-tooltip="-"
              >
                <div
                  id="boost_ram_bar"
                  class="absolute h-full rounded-md transition-all duration-300 bg-purple-400/70"
                  style="width: 0%"
                >
                </div>
                <div
                  id="ram_bar"
                  class="relative h-full rounded-md transition-all duration-300 bg-white"
                  style="width: 0%"
                >
                </div>
                <span
                  class="absolute inset-0 z-10 flex items-center justify-center text-[11px] font-semibold text-white"
                  style="text-shadow: 0 1px 2px rgba(0,0,0,0.8);"
                >
                  RAM
                </span>
              </div>
            </div>

            <div>
              <div
                class="w-full bg-white/5 rounded-md h-5 relative overflow-hidden"
                data-tooltip="-"
              >
                <div
                  id="boost_ssd_bar"
                  class="absolute h-full rounded-md transition-all duration-300 bg-purple-400/70"
                  style="width: 0%"
                >
                </div>
                <div
                  id="ssd_bar"
                  class="relative h-full rounded-md transition-all duration-300 bg-white"
                  style="width: 0%"
                >
                </div>
                <span
                  class="absolute inset-0 z-10 flex items-center justify-center text-[11px] font-semibold text-white"
                  style="text-shadow: 0 1px 2px rgba(0,0,0,0.8);"
                >
                  SSD STORAGE
                </span>
              </div>
            </div>
          </div>
        </div>

        <div class="w-36 shrink-0">
          <p class="block text-sm font-medium mb-2 text-center">Availability</p>

          <div
            id="availability_circle"
            class="relative w-28 h-28 mx-auto"
            data-tooltip="-"
          >
            <svg viewBox="0 0 100 100" class="w-full h-full -rotate-90">
              <!-- Track -->
              <circle
                cx="50"
                cy="50"
                r="42"
                stroke="rgba(255,255,255,0.15)"
                stroke-width="10"
                fill="none"></circle>

              <!-- Current availability (white, drawn first) -->
              <circle
                id="availability_base_circle"
                cx="50"
                cy="50"
                r="42"
                stroke="white"
                stroke-width="10"
                stroke-linecap="round"
                fill="none"
                stroke-dasharray="0 999"
                style="transition: stroke-dasharray 500ms ease, stroke-dashoffset 500ms ease;"
              ></circle>

              <!-- After-order availability (gray, drawn on top so it is visible) -->
              <circle
                id="availability_after_circle"
                cx="50"
                cy="50"
                r="42"
                stroke="rgb(156 163 175)"
                stroke-opacity="0.95"
                stroke-width="10"
                stroke-linecap="round"
                fill="none"
                stroke-dasharray="0 999"
                style="transition: stroke-dasharray 500ms ease, stroke-dashoffset 500ms ease;"
              ></circle>
            </svg>

            <div
              id="availability_percent_text"
              class="absolute inset-0 flex items-center justify-center text-sm font-semibold"
            >
              0%
            </div>
          </div>

          <p id="can_deploy" class="text-xs opacity-50 text-center mt-2">-</p>

          <!-- hidden compatibility bars for existing JS -->
          <div hidden id="availability_bar" data-tooltip="-">
            <div id="availability_after_bar" style="width: 0%"></div>
            <div id="availability_base_bar" style="width: 0%"></div>
          </div>
        </div>
      </div>

      <!-- Total cost -->
      <div class="flex justify-between items-center">
        <p class="text-lg font-semibold">Monthly Cost:</p>
        <p id="estimated_cost" class="text-4xl font-bold">-</p>
      </div>

      <!-- Line -->
      <hr class="border-white/25 my-5" />

      <div>
        <button
          id="place_order_btn"
          class="group w-full p-4 mt-5 gap-3 flex items-center border rounded-lg rounded-b-sm hover:bg-white/10 border-white/20 transition-all duration-300 ease-in-out"
        >
          <span
            class="w-full z-10 relative group-hover:text-white text-center transition-color duration-300"
          >
            Get My Server!
          </span>
        </button>

        <a
          href="https://billing.stripe.com/p/login/6oUaEWa7abrm9GSdzBdAk00"
          target="_blank"
          class="group w-full h-5 p-4 mt-2 gap-3 flex items-center border rounded-lg rounded-t-sm hover:bg-white/10 border-white/20 transition-all duration-300 ease-in-out"
        >
          <span
            class="w-full z-10 relative group-hover:text-white text-center transition-color duration-300"
          >
            Manage Subscriptions
          </span>
        </a>

        <a href="/legal">
          <small>
            By creating a server, you agree to our <strong
              >Terms of Service</strong
            > & <strong>Privacy Policy</strong>.
          </small>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  // ------------------------------
  // DOM ELEMENT REFERENCES
  // ------------------------------
  const locationOptions = document.getElementById(
    "location_options",
  ) as HTMLElement | null;

  const eggOptions = document.getElementById(
    "egg_options",
  ) as HTMLElement | null;
  const eggTemplate = document.getElementById(
    "egg_template",
  ) as HTMLElement | null;

  const subplanDropdown = document.getElementById(
    "subplan_dropdown",
  ) as HTMLElement | null;
  const subplanSelected = document.getElementById(
    "subplan_selected",
  ) as HTMLElement | null;
  const subplanOptions = document.getElementById(
    "subplan_options",
  ) as HTMLElement | null;

  const clientEmailInput = document.getElementById(
    "client_email",
  ) as HTMLInputElement | null;
  const placeOrderBtn = document.getElementById(
    "place_order_btn",
  ) as HTMLElement | null;
  const orderBlocker = document.getElementById(
    "order_blocker",
  ) as HTMLElement | null;
  const orderStatus = document.getElementById(
    "order_activity",
  ) as HTMLElement | null;

  const cpuBar = document.getElementById("cpu_bar") as HTMLElement | null;
  const ramBar = document.getElementById("ram_bar") as HTMLElement | null;
  const ssdBar = document.getElementById("ssd_bar") as HTMLElement | null;

  const boostCpuBar = document.getElementById(
    "boost_cpu_bar",
  ) as HTMLElement | null;
  const boostRamBar = document.getElementById(
    "boost_ram_bar",
  ) as HTMLElement | null;
  const boostSsdBar = document.getElementById(
    "boost_ssd_bar",
  ) as HTMLElement | null;

  const availabilityBar = document.getElementById(
    "availability_base_bar",
  ) as HTMLElement | null;
  const availabilityAfterBar = document.getElementById(
    "availability_after_bar",
  ) as HTMLElement | null;

  const availabilityBaseCircle = document.getElementById(
    "availability_base_circle",
  ) as SVGCircleElement | null;
  const availabilityAfterCircle = document.getElementById(
    "availability_after_circle",
  ) as SVGCircleElement | null;
  const availabilityPercentText = document.getElementById(
    "availability_percent_text",
  ) as HTMLElement | null;
  const availabilityCircle = document.getElementById(
    "availability_circle",
  ) as HTMLElement | null;

  const canDeployText = document.getElementById(
    "can_deploy",
  ) as HTMLElement | null;
  const estimatedCost = document.getElementById(
    "estimated_cost",
  ) as HTMLElement | null;
  // ------------------------------

  const egg_list = "https://api.nikostuff.com/HostingPelicanData?list_eggs";
  const order_api = "https://api.nikostuff.com/HostingOrderManager?place_order";
  const specs_api =
    "https://api.nikostuff.com/HostingOrderManager?retrive_data";

  const data_storage = {
    egg_id: "",
    client_email: "",
    location: "",
    subplan: "",
    turnstile_token: "",
  };

  const AVAILABILITY_RADIUS = 42;
  const AVAILABILITY_CIRCUMFERENCE = 2 * Math.PI * AVAILABILITY_RADIUS;

  function setStatus(text: string) {
    if (orderStatus) orderStatus.textContent = text;
  }

  function setSelectedEggOption(selectedOption: Element) {
    eggOptions?.querySelectorAll(".egg_option").forEach((option) => {
      if (!(option instanceof HTMLElement)) return;
      option.classList.remove(
        "border-white/40",
        "bg-white/10",
        "ring-1",
        "ring-white/30",
      );
      option.classList.add("border-transparent");
    });

    if (selectedOption instanceof HTMLElement) {
      selectedOption.classList.remove("border-transparent");
      selectedOption.classList.add(
        "border-white/40",
        "bg-white/10",
        "ring-1",
        "ring-white/30",
      );
    }
  }

  function setSelectedLocationOption(selectedOption: Element) {
    locationOptions
      ?.querySelectorAll("[data-location_name]")
      .forEach((option) => {
        if (!(option instanceof HTMLElement)) return;
        option.classList.remove(
          "border-white/40",
          "bg-white/10",
          "ring-1",
          "ring-white/30",
        );
        option.classList.add("border", "border-transparent");
      });

    if (selectedOption instanceof HTMLElement) {
      selectedOption.classList.remove("border-transparent");
      selectedOption.classList.add(
        "border",
        "border-white/40",
        "bg-white/10",
        "ring-1",
        "ring-white/30",
      );
    }
  }

  // ------------------------------
  // UPDATE STATS AND COST FUNCTION
  // ------------------------------
  async function updateSpecsAndCost() {
    if (!data_storage.egg_id || !data_storage.location || !data_storage.subplan)
      return;

    try {
      const res = await fetch(specs_api, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          egg_id: data_storage.egg_id,
          location: data_storage.location,
          subplan: data_storage.subplan,
        }),
      });

      if (!res.ok) throw new Error("Failed to fetch specs and cost");
      const data = await res.json();

      const canDeploy =
        typeof data.can_deploy === "boolean" ? data.can_deploy : false;

      const cpuBaseRaw = Math.max(0, Number(data.cpu) || 0);
      const cpuBoostRaw = Math.max(0, Number(data.boost?.cpu) || 0);
      const cpuTotalRaw = cpuBaseRaw + cpuBoostRaw;
      const cpuMaxTotal = 800;
      const cpuBase = Math.min(100, (cpuBaseRaw / cpuMaxTotal) * 100);
      const cpuTotal = Math.min(100, (cpuTotalRaw / cpuMaxTotal) * 100);

      const ramBaseRaw = Math.max(0, Number(data.ram) || 0);
      const ramBoostRaw = Math.max(0, Number(data.boost?.ram) || 0);
      const ramBase = Math.max(0, Math.min(100, ramBaseRaw));
      const ramTotal = Math.max(0, Math.min(100, ramBaseRaw + ramBoostRaw));

      const ssdBaseRaw = Math.max(0, Number(data.disk) || 0);
      const ssdBoostRaw = Math.max(0, Number(data.boost?.disk) || 0);
      const ssdBase = Math.max(0, Math.min(100, ssdBaseRaw));
      const ssdTotal = Math.max(0, Math.min(100, ssdBaseRaw + ssdBoostRaw));

      if (cpuBar) {
        cpuBar.style.width = `${cpuBase}%`;
        cpuBar.parentElement?.setAttribute(
          "data-tooltip",
          `${cpuBaseRaw}%+${cpuBoostRaw}% CPU (total ${cpuTotalRaw}% CPU)`,
        );
      }
      if (boostCpuBar) boostCpuBar.style.width = `${cpuTotal}%`;

      if (ramBar) {
        ramBar.style.width = `${ramBase}%`;
        ramBar.parentElement?.setAttribute(
          "data-tooltip",
          `${ramBaseRaw}+${ramBoostRaw} GB RAM (total ${ramBaseRaw + ramBoostRaw} GB)`,
        );
      }
      if (boostRamBar) boostRamBar.style.width = `${ramTotal}%`;

      if (ssdBar) {
        ssdBar.style.width = `${ssdBase}%`;
        ssdBar.parentElement?.setAttribute(
          "data-tooltip",
          `${ssdBaseRaw}+${ssdBoostRaw} GB Storage (total ${ssdBaseRaw + ssdBoostRaw} GB) </br> *Expandable storage - free of charge. Contact us via ticketing system after placing the order if you need more storage!`,
        );
      }
      if (boostSsdBar) boostSsdBar.style.width = `${ssdTotal}%`;

      if (estimatedCost) estimatedCost.textContent = `$${data.price}`;

      const availability = Math.max(
        0,
        Math.min(100, Number(data.availability) || 0),
      );
      const availabilityAfter = Math.max(
        0,
        Math.min(100, Number(data.availability_after) || 0),
      );

      if (availabilityBar) availabilityBar.style.width = `${availability}%`;
      if (availabilityAfterBar)
        availabilityAfterBar.style.width = `${availabilityAfter}%`;

      if (availabilityCircle) {
        availabilityCircle.setAttribute(
          "data-tooltip",
          `${availability}% Available Resources ( After this order, ${availabilityAfter}% will be available )`,
        );
      }

      if (availabilityBaseCircle) {
        const dash = (availability / 100) * AVAILABILITY_CIRCUMFERENCE;
        availabilityBaseCircle.setAttribute("stroke-dasharray", `${dash} 999`);
      }

      if (availabilityAfterCircle) {
        const dashAfter =
          (availabilityAfter / 100) * AVAILABILITY_CIRCUMFERENCE;
        availabilityAfterCircle.setAttribute(
          "stroke-dasharray",
          `${dashAfter} 999`,
        );
      }

      if (availabilityPercentText)
        availabilityPercentText.textContent = `${availability}%`;

      if (canDeployText) {
        canDeployText.textContent = canDeploy
          ? "Your server can be deployed!"
          : "Your server cannot be deployed due to insufficient resources.";
      }
    } catch (err) {
      console.error("Error updating specs and cost:", err);
    }
  }

  // ------------------------------
  // CLIENT EMAIL INPUT HANDLING
  // ------------------------------
  let emailTimer: ReturnType<typeof setTimeout> | undefined;
  function commitEmail() {
    if (!clientEmailInput) return;
    data_storage.client_email = clientEmailInput.value.trim();
  }

  clientEmailInput?.addEventListener("input", () => {
    if (emailTimer) clearTimeout(emailTimer);
    emailTimer = setTimeout(commitEmail, 2000);
  });

  clientEmailInput?.addEventListener("blur", () => {
    if (emailTimer) clearTimeout(emailTimer);
    commitEmail();
  });

  // ------------------------------
  // Cloudflare Turnstile callbacks
  // ------------------------------
  (window as any).onTurnstileSuccess = (token: string) => {
    data_storage.turnstile_token = token || "";
  };
  (window as any).onTurnstileExpired = () => {
    data_storage.turnstile_token = "";
  };

  // ------------------------------
  // FETCH EGGS
  // ------------------------------
  type Egg = { id: number; name: string; desc: string; image: string };

  async function fetchEggs() {
    try {
      const res = await fetch(egg_list);
      if (!res.ok) throw new Error("Failed to fetch eggs");

      const data = await res.json();
      const grid = eggOptions?.querySelector(".p-3");
      if (!grid || !eggTemplate) return;

      grid.querySelectorAll(".egg_option").forEach((el) => el.remove());

      const eggs = Object.values(data).filter(
        (item): item is Egg =>
          typeof item === "object" && item !== null && "id" in item,
      );

      for (const egg of eggs) {
        const eggOption = eggTemplate.cloneNode(true);
        if (!(eggOption instanceof HTMLElement)) continue;

        eggOption.id = "";
        eggOption.classList.add("egg_option", "border", "border-transparent");
        eggOption.dataset.egg_id = String(egg.id);
        eggOption.dataset.tooltip = egg.desc;
        eggOption.hidden = false;

        const img = eggOption.querySelector("img");
        if (img) {
          img.src = egg.image || "/imgs/plc.png";
          img.alt = egg.name || "";
        }

        const label = eggOption.querySelector("span");
        if (label) label.textContent = egg.name || "";

        eggOption.addEventListener("click", () => {
          data_storage.egg_id = eggOption.getAttribute("data-egg_id") || "";
          setSelectedEggOption(eggOption);
          updateSpecsAndCost();
        });

        grid.appendChild(eggOption);
      }
    } catch (e) {
      console.error(e);
    }
  }

  // ------------------------------
  // DROPDOWN HANDLERS
  // ------------------------------
  subplanSelected?.addEventListener("click", () => {
    subplanOptions?.classList.toggle("max-h-60");
  });

  document.addEventListener("click", (e) => {
    const target = e.target;
    if (!(target instanceof Node) || !subplanDropdown?.contains(target)) {
      subplanOptions?.classList.remove("max-h-60");
    }
  });

  setInterval(updateSpecsAndCost, 2000);

  // ------------------------------
  // LOCATION PICKER SELECT
  // ------------------------------
  locationOptions
    ?.querySelectorAll("[data-location_name]")
    .forEach((option) => {
      if (option instanceof HTMLElement)
        option.classList.add("border", "border-transparent");

      option.addEventListener("click", () => {
        data_storage.location = option.getAttribute("data-location_name") || "";
        setSelectedLocationOption(option);
        updateSpecsAndCost();
      });
    });

  // ------------------------------
  // SUBPLAN OPTION SELECT
  // ------------------------------
  subplanOptions?.querySelectorAll("[data-subplan_name]").forEach((option) => {
    option.addEventListener("click", () => {
      if (!subplanSelected || !subplanOptions) return;
      subplanSelected.innerHTML = option.innerHTML;
      data_storage.subplan = option.getAttribute("data-subplan_name") || "";
      subplanOptions.classList.remove("max-h-60");
      updateSpecsAndCost();
    });
  });

  // ------------------------------
  // PLACE ORDER
  // ------------------------------
  placeOrderBtn?.addEventListener("click", async () => {
    if (emailTimer) clearTimeout(emailTimer);
    commitEmail();

    if (orderBlocker) orderBlocker.removeAttribute("hidden");

    try {
      setStatus("Waiting for API response...");

      const res = await fetch(order_api, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data_storage),
      });

      if (!res.ok)
        throw new Error("Unknown error... (Can't reach the target URL)");

      const data = await res.json();
      if (data.error) throw new Error(data.error);

      if (data.status === "task_created") {
        setStatus("Action completed successfully! Redirecting...");
        setTimeout(() => {
          if (orderBlocker) orderBlocker.setAttribute("hidden", "true");
          const redirectUrl =
            typeof data.redirect_url === "string"
              ? data.redirect_url
              : "https://panel.nikostuff.com";
          window.location.href = redirectUrl;
        }, 3000);
      } else {
        if (orderBlocker) orderBlocker.setAttribute("hidden", "true");
        alert("Oops. Something went wrong. Please try again later.");
      }
    } catch (err) {
      console.error(err);
      if (orderBlocker) orderBlocker.setAttribute("hidden", "true");
      const errMsg =
        err && typeof err === "object" && "message" in err
          ? (err as any).message
          : String(err);
      alert("Failed to place order: " + errMsg);
    }

    if ((window as any).turnstile?.reset) (window as any).turnstile.reset();
  });

  // ------------------------------
  // INIT
  // ------------------------------
  fetchEggs();
</script>
