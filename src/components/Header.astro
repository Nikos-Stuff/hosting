---
import { SITE, LINKS } from "@consts";
import { cn } from "@lib/utils";
const { pathname } = Astro.url;
const subpath = pathname.match(/[^/]+/g);
import Container from "@components/Container.astro";
import HeaderIcon from "@components/web_icon.astro";
---

<header id="header" class="fixed top-0 w-full h-16 z-40 drop-shadow-2xl">
  <Container size="lg">
    <div class="relative h-full w-full">
      <div
        class="absolute left-0 top-1/2 -translate-y-1/2 flex gap-1 font-semibold hover:scale-110 transition-all duration-300"
      >
        <a
          href="/"
          class="flex gap-3 place-items-center w-fit font-semibold text-current hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out"
        >
          <HeaderIcon />
          <div>Hosting</div>
        </a>
      </div>

      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <nav class="hidden lg:flex items-center justify-center text-sm gap-1">
          {
            LINKS.map((LINK) => (
              <a
                href={LINK.HREF}
                class={cn(
                  "h-8 rounded-full px-3 text-current whitespace-nowrap",
                  "flex items-center justify-center",
                  "transition-colors duration-300 ease-in-out",
                  pathname === LINK.HREF || "/" + subpath?.[0] === LINK.HREF
                    ? "bg-black dark:bg-white text-white dark:text-black hover:bg-[#737373] transition-all duration-300 ease-in-out"
                    : "hover:bg-black/5 dark:hover:bg-white/20 hover:text-black dark:hover:text-white",
                )}
              >
                {LINK.TEXT}
              </a>
            ))
          }
        </nav>
      </div>

      <div class="buttons absolute right-0 top-1/2 -translate-y-1/2 flex gap-1">
        <button
          data-tooltip="?"
          id="server-latency-pill"
          class="flex items-center justify-center bg-blue-500/20 border border-black/10 dark:border-white/25 text-sm font-medium px-3 py-1 rounded-full transition-all duration-300"
        >
          Ping: <span id="average-ping" class="ml-1">0</span> ms
        </button>

        <div
          data-tooltip="Amount of created accounts"
          id="active-users-pill"
          class="flex items-center justify-center bg-green-500/20 border border-black/10 dark:border-white/25 text-sm font-medium px-3 py-1 rounded-full transition-all duration-300"
        >
          Users: <span id="active-users-count" class="ml-1">0</span>
        </div>

        <button
          data-tooltip="Toggle theme"
          id="header-theme-button"
          aria-label={`Toggle light and dark theme`}
          class={cn(
            "flex",
            "size-9 rounded-full p-2 items-center justify-center",
            "bg-transparent hover:bg-black/5 dark:hover:bg-white/20",
            "stroke-current hover:stroke-black hover:dark:stroke-white",
            "border border-black/10 dark:border-white/25",
            "transition-all duration-300 ease-in-out",
          )}
        >
          <div class="size-full block dark:hidden">
            <i class="ph ph-sun"></i>
          </div>
          <div class="size-full hidden dark:block">
            <i class="ph ph-moon"></i> 
          </div>
        </button>
      </div>
    </div>
  </Container>
</header>

<style>
  #header-drawer-button > #drawer-open {
    @apply block;
  }

  #header-drawer-button > #drawer-close {
    @apply hidden;
  }

  #header-drawer-button.open > #drawer-open {
    @apply hidden;
  }

  #header-drawer-button.open > #drawer-close {
    @apply block;
  }
</style>

<script>
  import gsap from "gsap";

  const pill = document.getElementById("active-users-count");
  const pingSpan = document.getElementById("average-ping");
  const pingPopup = document.getElementById("ping_analysis_popup");

  if (!pill || !pingSpan) throw new Error("Required elements not found");

  let currentUsers = Number(pill.textContent) || 0;
  let currentPing = Number(pingSpan.textContent) || 0;

  const animateValue = (
    el: HTMLElement,
    start: number,
    end: number,
    duration: number,
    decimals = 0,
  ) => {
    const startTime = performance.now();

    const tick = (now: number) => {
      const progress = Math.min((now - startTime) / duration, 1);
      const value = start + (end - start) * progress;

      el.textContent = value.toFixed(decimals);

      if (progress < 1) requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);
  };

  const fetchJSON = async (url: string | URL | Request) => {
    const res = await fetch(url);
    if (!res.ok) throw new Error("Fetch failed");
    return res.json();
  };

  const updateActiveUsers = async () => {
    try {
      const { active_users } = await fetchJSON(
        "https://api.nikostuff.com/HostingPelicanData?active_users",
      );

      if (active_users !== currentUsers) {
        animateValue(pill, currentUsers, active_users, 500);
        currentUsers = active_users;
      }
    } catch (e) {
      console.error("Active users update failed:", e);
    }
  };

  // -- PING LOGIC --

  interface Node {
    name: string;
    url: string;
    region: string;
  }

  interface NodeWithPing extends Node {
    ping: number;
  }

  const nodes: Node[] = [
    { name: "PL #0", url: "https://testnode.nikostuff.com", region: "PL" },
    { name: "US #0", url: "https://usnode0.nikostuff.com", region: "US" },
  ];

  const nodeHistoryMap = new Map<string, number[]>();

  const getHistoryForNode = (url: string): number[] => {
    if (!nodeHistoryMap.has(url)) nodeHistoryMap.set(url, []);
    return nodeHistoryMap.get(url)!;
  };

  let pingRunning = false;
  const pingHistory: number[] = [];

  const pingNode = async (url: string, history: number[], retries = 3) => {
    for (let attempt = 0; attempt < retries; attempt++) {
      const start = performance.now();
      const controller = new AbortController();
      const timeout = setTimeout(() => controller.abort(), 8000);

      try {
        await fetch(url, {
          method: "HEAD",
          mode: "no-cors",
          cache: "no-store",
          signal: controller.signal,
        });

        clearTimeout(timeout);
        const ping = Math.round(performance.now() - start);

        const avg =
          history.length > 0
            ? history.reduce((a, b) => a + b) / history.length
            : ping;

        // Only accept if it's not a massive spike or if it's our first measurement
        if (ping < avg * 3 || history.length === 0) {
          history.push(ping);
          if (history.length > 5) history.shift();
          return ping;
        }
      } catch {
        clearTimeout(timeout);
      }
    }
    return Infinity;
  };

  const updatePing = async () => {
    if (pingRunning) return;
    pingRunning = true;

    try {
      const results: NodeWithPing[] = await Promise.all(
        nodes.map(async (node) => ({
          ...node,
          ping: await pingNode(node.url, getHistoryForNode(node.url)),
        })),
      );

      const validNodes = results.filter((n) => n.ping !== Infinity);
      if (!validNodes.length) return;

      const recommendedNode = validNodes.reduce((best, node) =>
        node.ping < best.ping ? node : best,
      );
      console.log("Recommended:", recommendedNode.name);

      const latencyPill = document.getElementById("server-latency-pill");
      if (latencyPill) {
        latencyPill.setAttribute(
          "data-tooltip",
          `Best Node: ${recommendedNode.name} (${recommendedNode.region})`,
        );
      }

      animateValue(pingSpan, currentPing, recommendedNode.ping, 500);
      currentPing = recommendedNode.ping;

      console.table(
        results.map(({ name, region, ping }) => ({
          Node: name,
          Region: region,
          Ping: ping === Infinity ? "Timeout" : `${ping} ms`,
        })),
      );
    } finally {
      pingRunning = false;
    }
  };

  updateActiveUsers();
  updatePing();

  setInterval(updateActiveUsers, 60000);
  setInterval(updatePing, 5000);

  const sleep = (ms: number | undefined) =>
    new Promise((resolve) => setTimeout(resolve, ms));

  pingSpan.parentElement?.addEventListener("click", async () => {
    const popup = document.getElementById("ping_analysis_popup");

    if (!popup) return;

    const modal = popup.firstElementChild;
    const pingDisplay = document.getElementById("popup-ping-value");
    const statusDisplay = document.getElementById("popup-status-text");
    const jitterDisplay = document.getElementById("popup-jitter-value");

    if (!popup || !modal || !pingDisplay || !statusDisplay || !jitterDisplay)
      return;

    // reset the stuff for the new analysis
    jitterDisplay.textContent = `Measuring stats...`;
    pingDisplay.textContent = `--ms`;
    statusDisplay.textContent = `Initializing...`; 

    popup.classList.remove("hidden");
    popup.classList.add("flex");
    gsap.set(popup, {
      backgroundColor: "rgba(0,0,0,0)",
      backdropFilter: "blur(0px)",
    });

    gsap.to(popup, {
      backgroundColor: "rgba(0,0,0,0.5)",
      backdropFilter: "blur(16px)",
      duration: 0.4,
    });
    gsap.fromTo(
      modal,
      { scale: 0.9, opacity: 0 },
      { scale: 1, opacity: 1, duration: 0.4, ease: "back.out(1.7)" },
    );

    let bestOverall = { ping: Infinity, name: "", region: "" };

    for (const node of nodes) {
      let totalPing = 0;
      let successfulPings = 0;

      // CREATE LOCAL HISTORY FOR THIS SPECIFIC ANALYSIS
      const localHistory: number[] = [];

      for (let i = 1; i <= 10; i++) {
        statusDisplay.textContent = `Testing ${node.name} (${node.region}) - Attempt ${i}/10`;

        // PASS THE LOCAL HISTORY
        const ping = await pingNode(node.url, localHistory);

        if (ping !== Infinity) {
          totalPing += ping;
          successfulPings++;

          // "Tick" Animation
          gsap.fromTo(
            pingDisplay,
            { scale: 1.1, color: "#3b82f6" },
            { scale: 1, color: "inherit", duration: 0.2 },
          );
          pingDisplay.textContent = `${ping}ms`;
        }
        await sleep(500);
      }

      if (successfulPings > 1) {
        const diffs = [];
        for (let j = 1; j < localHistory.length; j++) {
          diffs.push(Math.abs(localHistory[j] - localHistory[j - 1]));
        }
        const jitter = Math.round(diffs.reduce((a, b) => a + b) / diffs.length);
        jitterDisplay.textContent = `Jitter: ${jitter}ms (±${Math.round(jitter / 2)}ms) | ${localHistory.length} samples | ${successfulPings} successful`;
      } else {
        jitterDisplay.textContent = `Not enough successful pings to calculate stats (0 or 1 successful) | Region ${node.region}`;
      }

      if (successfulPings > 0) {
        const avg = Math.round(totalPing / successfulPings);
        if (avg < bestOverall.ping) {
          bestOverall = { ping: avg, name: node.name, region: node.region };
        }
      }

      // wait a bit before next node
      await sleep(3500);
      // reset the jitter display & ping display for the next node

      jitterDisplay.textContent = `Measuring stats...`;
      pingDisplay.textContent = `--ms`;
    }

    statusDisplay.textContent = `Best: ${bestOverall.name} (${bestOverall.region})`;
    pingDisplay.textContent = `${bestOverall.ping}ms`;
    jitterDisplay.textContent = `Done!`;
    gsap.to(pingDisplay, { scale: 1.2, duration: 0.3, yoyo: true, repeat: 1 });

    await sleep(5000);
    gsap.to(popup, {
      backgroundColor: "rgba(0,0,0,0)",
      backdropFilter: "blur(0px)",
      duration: 0.3,
    });
    gsap.to(modal, {
      scale: 0.9,
      opacity: 0,
      duration: 0.3,
      onComplete: () => {
        popup.classList.add("hidden");
        popup.classList.remove("flex");
      },
    });
  });
</script>
